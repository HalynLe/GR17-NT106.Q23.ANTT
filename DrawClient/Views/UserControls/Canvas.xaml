<UserControl x:Class="DrawClient.Views.UserControls.Canvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DrawClient.Views.UserControls"
             xmlns:converters="clr-namespace:DrawClient.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#FFFFFF">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:HexToBrushConverter x:Key="HexToBrushConverter"/>
        <Style x:Key="PenTypeRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#E8F0FE"/>
                                <Setter Property="Foreground" Value="#1A73E8"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#F1F3F4"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ColorRadioStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Ellipse x:Name="OuterRing" Width="30" Height="30" Stroke="Transparent" StrokeThickness="2"/>
                            <Ellipse x:Name="InnerColor" Width="20" Height="20" Fill="{TemplateBinding Background}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OuterRing" Property="Stroke" Value="#1A73E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SizeDotRadioStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="#5F6368"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Margin" Value="0,0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Width="32" Height="32" Background="Transparent">
                            <Ellipse x:Name="OuterBorder" Width="30" Height="30" 
                                   Stroke="Transparent" StrokeThickness="2" Fill="Transparent"/>

                            <Ellipse x:Name="InnerDot" 
                                   Width="{TemplateBinding FontSize}" 
                                   Height="{TemplateBinding FontSize}" 
                                   Fill="{TemplateBinding Background}" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OuterBorder" Property="Stroke" Value="#1A73E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="VectorToolStyle" TargetType="Button" >
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borderBg" 
                            CornerRadius="20" 
                            Background="{TemplateBinding Background}">

                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="4"
                                  Width="18" Height="18"/>

                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borderBg" Property="Background" Value="#F1F3F4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="borderBg" Property="Background" Value="#E8F0FE"/>
                                <Setter Property="Foreground" Value="#1A73E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RadioToolStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border CornerRadius="20" Background="{TemplateBinding Background}">
                            <Path x:Name="ToolIcon" 
                                  Data="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.5"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="18" Height="18"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#E8F0FE"/>
                                <Setter Property="Foreground" Value="#1A73E8"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#F1F3F4"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 1. STYLE Menu Items -->
        <Style x:Key="MaterialComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F3F4"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8F0FE"/>
                                <Setter Property="Foreground" Value="#1A73E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 2. NÚT BẤM CỦA COMBOBOX -->
        <ControlTemplate x:Key="MaterialComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Border x:Name="border" Background="#FFFFFF" BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="4" SnapsToDevicePixels="True"/>
                <Border x:Name="focusBorder" Background="Transparent" BorderBrush="#1A73E8" BorderThickness="2" CornerRadius="4" Opacity="0" SnapsToDevicePixels="True"/>
                <Path x:Name="arrow" Data="M 0,0 L 4,5 L 8,0 Z" Fill="#5F6368" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="BorderBrush" Value="#5F6368"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="focusBorder" Property="Opacity" Value="1"/>
                    <Setter TargetName="border" Property="Opacity" Value="0"/>
                    <Setter TargetName="arrow" Property="Fill" Value="#1A73E8"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <!-- 3. STYLE CHÍNH CHO COMBOBOX -->
        <Style x:Key="MaterialComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                      Template="{StaticResource MaterialComboBoxToggleButton}" 
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="False"/>
                            <ContentPresenter IsHitTestVisible="False" 
                                          Content="{TemplateBinding SelectionBoxItem}" 
                                          Margin="12,8,30,8" 
                                          VerticalAlignment="Center" 
                                          HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#FFFFFF" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="4" Margin="0,4,0,8"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#3C4043"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True" MaxHeight="200">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- STYLE CHO CÁC NÚT CHỌN MÀU (Viền xám, hover đậm viền, không bị xanh) -->
        <Style x:Key="OutlinedColorButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            CornerRadius="4" 
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Khi di chuột vào: Đậm viền lên màu #5F6368 và nền hơi xám nhẹ-->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5F6368"/>
                                <Setter TargetName="border" Property="Background" Value="#F8F9FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="1200"/>
            <ColumnDefinition Width="0*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
        Background="#FFFFFF"
        BorderBrush="#E8EAED"
        BorderThickness="0,0,0,1"
        Padding="24,0"
        Panel.ZIndex="10">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left -->
                <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <!-- Back -->
                    <Button Command="{Binding LeaveRoomCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="0,0,16,0"
                    Cursor="Hand"
                    ToolTip="Leave Room"
                    Style="{StaticResource VectorToolStyle}"
                    Width="36"
                    Height="36">

                        <Path Data="M 18,2 L 6,12 18,22"
                      Stroke="Black"
                      StrokeThickness="1.5"
                      StrokeLineJoin="Round"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Fill="Transparent"
                      Stretch="Uniform"
                      Width="18"
                      Height="18"
                      Margin="-2,0,0,0"/>
                    </Button>

                    <!-- Divider -->
                    <Rectangle Width="1"
                       Height="24"
                       Fill="#E8EAED"
                       Margin="0,0,5,0"/>

                    <!-- Room Name -->
                    <Button Command="{Binding ShowRoomInfoCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="10,0,20,0"
                    FocusVisualStyle="{x:Null}">

                        <Button.ToolTip>
                            <ToolTip Content="Nhấp để xem Mã phòng và Mật khẩu"/>
                        </Button.ToolTip>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <TextBlock Text="{Binding RoomName}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#202124"
                                   VerticalAlignment="Center"/>

                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Divider -->
                    <Rectangle Width="1"
                       Height="24"
                       Fill="#E8EAED"
                       Margin="0,0,16,0"/>

                    <!-- Undo -->
                    <Button Command="{Binding UndoCommand}"
                    Width="36"
                    Height="36"
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    ToolTip="Undo"
                    Cursor="Hand"
                    Style="{StaticResource VectorToolStyle}">

                        <Path Data="M3 7v6h6 M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"
                      Stroke="#5F6368"
                      StrokeThickness="1.5"
                      Fill="Transparent"
                      Width="18"
                      Height="18"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      StrokeLineJoin="Round"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"/>
                    </Button>

                    <!-- Redo -->
                    <Button Command="{Binding RedoCommand}"
                    Width="36"
                    Height="36"
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTip="Redo"
                    Cursor="Hand"
                    Style="{StaticResource VectorToolStyle}">

                        <Path Data="M21 7v6h-6 M3 17a9 9 0 0 1 9-9 9 9 0 0 1 6 2.3l3 2.7"
                      Stroke="#5F6368"
                      StrokeThickness="1.5"
                      Fill="Transparent"
                      Width="18"
                      Height="18"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      StrokeLineJoin="Round"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"/>
                    </Button>

                </StackPanel>

                <!-- Center -->
                <Border Grid.Column="1"
                Background="#F8F9FA"
                CornerRadius="8"
                Margin="40,12"
                Padding="16,0"
                MaxWidth="500">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <!-- Play -->
                        <Button Grid.Column="0"
                        Width="36"
                        Height="36"
                        Background="Transparent"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Style="{StaticResource VectorToolStyle}">

                            <Path Data="M5 3 L19 12 L5 21 Z"
                          Stroke="#5F6368"
                          StrokeThickness="1.5"
                          Fill="Transparent"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          Margin="2.5,0,0,0"/>
                        </Button>

                        <!-- Slider -->
                        <Slider Grid.Column="1"
                        Minimum="0"
                        Maximum="100"
                        Value="0"
                        VerticalAlignment="Center"
                        Margin="16,0">

                            <Slider.Template>

                                <ControlTemplate TargetType="Slider">

                                    <Grid VerticalAlignment="Center">

                                        <!-- Track BG -->
                                        <Border Height="4"
                                        Background="#DADCE0"
                                        CornerRadius="2"
                                        VerticalAlignment="Center"/>

                                        <Track x:Name="PART_Track">

                                            <!-- Filled -->
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                      Focusable="False">

                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="RepeatButton">

                                                            <Border Height="4"
                                                            Background="#1A73E8"
                                                            CornerRadius="2,0,0,2"
                                                            VerticalAlignment="Center"/>

                                                        </ControlTemplate>
                                                    </RepeatButton.Template>

                                                </RepeatButton>
                                            </Track.DecreaseRepeatButton>

                                            <!-- Empty -->
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                      Focusable="False">

                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="RepeatButton">
                                                            <Border Background="Transparent"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>

                                                </RepeatButton>
                                            </Track.IncreaseRepeatButton>

                                            <!-- Thumb -->
                                            <Track.Thumb>

                                                <Thumb Focusable="False">

                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">

                                                            <Ellipse Width="14"
                                                             Height="14"
                                                             Fill="#1A73E8">

                                                                <Ellipse.Effect>
                                                                    <DropShadowEffect BlurRadius="4"
                                                                              ShadowDepth="1"
                                                                              Opacity="0.25"
                                                                              Color="#3C4043"/>
                                                                </Ellipse.Effect>

                                                            </Ellipse>

                                                        </ControlTemplate>
                                                    </Thumb.Template>

                                                </Thumb>

                                            </Track.Thumb>

                                        </Track>

                                    </Grid>

                                </ControlTemplate>

                            </Slider.Template>

                        </Slider>

                        <!-- Percent -->
                        <TextBlock Grid.Column="2"
                           Text="0%"
                           Foreground="#5F6368"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontSize="13"/>

                    </Grid>

                </Border>

                <!-- Profile -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <Button Width="36"
            Height="36"
            Margin="0,0,16,0"
            Background="Transparent"
            BorderThickness="0"
            Cursor="Hand"
            ToolTip="Toggle Chat &amp; Status"
            FocusVisualStyle="{x:Null}"
            Style="{StaticResource VectorToolStyle}"
            Command="{Binding ToggleSidebarCommand}">

                        <Path Data="M 8 3 H 16 A 5 5 0 0 1 21 8 V 16 A 5 5 0 0 1 16 21 H 8 A 5 5 0 0 1 3 16 V 8 A 5 5 0 0 1 8 3 Z M 10.5 3 V 21 M 5.5 7.5 H 7 M 5.5 10.5 H 7"
      Stroke="Black"
      StrokeThickness="1.8"
      StrokeStartLineCap="Round"
      StrokeEndLineCap="Round"
      StrokeLineJoin="Round"
      Fill="Transparent"
      Stretch="Uniform" Margin="-4,-1,-4,-2"/>
                    </Button>

                    <Button x:Name="ProfileButton"
            Width="32"
            Height="32"
            Background="Transparent"
            BorderThickness="0"
            Cursor="Hand"
            FocusVisualStyle="{x:Null}"
            Command="{Binding ToggleProfilePopoverCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="32" Height="32" Background="#1A73E8" CornerRadius="16">
                                    <TextBlock Text="{Binding CurrentUserInitials}"
                               Foreground="White" FontSize="14" FontWeight="Medium"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>



        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding RightSidebarWidth}"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" ClipToBounds="True">

                <Grid>

                    <!-- Canvas vẽ -->
                    <InkCanvas x:Name="inkCanvas" IsHitTestVisible="False" EditingMode="None"/>

                    <!-- Laser pointer -->
                    <Canvas x:Name="laserCanvas"
                            IsHitTestVisible="False"
                            Panel.ZIndex="50">

                        <Ellipse x:Name="laserDot"
                                 Width="24"
                                 Height="24"
                                 Opacity="0"
                                 Visibility="Collapsed"
                                 IsHitTestVisible="False">
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                    <GradientStop Color="#FFFFE066" Offset="0"/>
                                    <GradientStop Color="#80FF6A00" Offset="0.5"/>
                                    <GradientStop Color="#00FF6A00" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#FFFFA000" BlurRadius="18" ShadowDepth="0" Opacity="0.9"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Canvas>

                </Grid>

                <InkCanvas x:Name="MyCanvas"
                           Grid.Column="0"
                           EditingMode="{Binding CurrentEditingMode}" 
                           SnapsToDevicePixels="True"
                           MouseDown="Canvas_MouseDown"
                           MouseUp="Canvas_MouseUp"
                           MouseMove="Canvas_MouseMove" Margin="0,0,-592,0">


                    <Ellipse x:Name="EraserCursor" 
                             IsHitTestVisible="False" 
                             Width="{Binding Toolbar.CurrentThickness}" 
                             Height="{Binding Toolbar.CurrentThickness}" 
                             Stroke="#5F6368" StrokeThickness="1.2" 
                             Fill="#22808080" Visibility="Collapsed" 
                             HorizontalAlignment="Left" VerticalAlignment="Top" Panel.ZIndex="999"/>
                    <InkCanvas.Background>
                        <DrawingBrush Viewport="0,0,30,30" ViewportUnits="Absolute" TileMode="Tile" Stretch="None">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="#B0B5B9">
                                    <GeometryDrawing.Geometry>
                                        <EllipseGeometry RadiusX="1" RadiusY="1" Center="0,0"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </InkCanvas.Background>


                </InkCanvas>

                <Canvas x:Name="OverlayCanvas" Panel.ZIndex="2" IsHitTestVisible="False">

                    <Canvas Canvas.Left="350" Canvas.Top="200"/>

                    <Canvas Canvas.Left="700" Canvas.Top="320"/>
                </Canvas>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="24,0,0,0" Panel.ZIndex="100">

                    <Border VerticalAlignment="Center" Background="#FFFFFF" CornerRadius="24" Padding="4,12" Panel.ZIndex="5" Width="52">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.15" Color="#3C4043"/>
                        </Border.Effect>

                        <StackPanel Width="40">

                            <!-- SELECT -->
                            <RadioButton GroupName="Tools"
                         Width="40"
                         Height="40"
                         Margin="0,0,0,8"
                         ToolTip="Select Tool"
                         Style="{StaticResource RadioToolStyle}"
                         Command="{Binding SelectToolCommand}"
                         CommandParameter="select"
                         IsChecked="True"
                         Content="M4.037 4.688a.495.495 0 0 1 .651-.651l16 6.5a.5.5 0 0 1-.063.947l-6.124 1.58a2 2 0 0 0-1.438 1.435l-1.579 6.126a.5.5 0 0 1-.947.063z"/>

                            <!-- PEN -->
                            <RadioButton x:Name="PenButton"
               GroupName="Tools"
               Width="40"
               Height="40"
               Margin="0,0,0,8"
               ToolTip="Pen Tools"
               Style="{StaticResource RadioToolStyle}"
               Command="{Binding Toolbar.TogglePopupCommand}"
               CommandParameter="Pencil"
               Content="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z M15 5l4 4"
               Focusable="False"
               IsChecked="{Binding Toolbar.IsPencilSelected, Mode=TwoWay}"/>
                            <!-- ERASER -->
                            <RadioButton x:Name="EraserButton"
               GroupName="Tools"
               Width="40"
               Height="40"
               Margin="0,0,0,8"
               ToolTip="Eraser"
               Style="{StaticResource RadioToolStyle}"
               Command="{Binding Toolbar.TogglePopupCommand}"
               CommandParameter="Eraser"
               Content="m7 21-4.3-4.3c-1-1-1-2.5 0-3.4l9.6-9.6c1-1 2.5-1 3.4 0l5.6 5.6c1 1 1 2.5 0 3.4L13 21 M22 21H7 M5 11l9 9"
               Focusable="False"
               IsChecked="{Binding Toolbar.IsEraserSelected, Mode=TwoWay}"/>

                            <!-- SHAPES -->
                            <RadioButton x:Name="ShapesButton"

                                    Height="32"
                                    Background="#1A73E8"
                                    CornerRadius="16"
                                    VerticalAlignment="Top">

                                                        <TextBlock Text="{Binding UserInitials}"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                        Margin="8,0,0,0"
                                        MaxWidth="240"
                                        HorizontalAlignment="Left">

                                                        <TextBlock Text="{Binding User}"
                                           Margin="12,0,0,4"
                                           FontSize="10"
                                           Foreground="#80868B"
                                           MaxWidth="180"
                                           TextWrapping="Wrap"
                                                                   FontWeight="Medium"/>

                                                        <Border Background="#F1F3F4"
                                        CornerRadius="14"
                                        Padding="12,8"
                                        HorizontalAlignment="Left">

                                                            <TextBlock Text="{Binding Message}"
                                               FontSize="13"
                                               Foreground="#202124"
                                               TextWrapping="Wrap"/>
                                                        </Border>

                                                        <TextBlock Text="{Binding Time}"
                                           Margin="12,4,0,0"
                                           FontSize="10"
                                           Foreground="#80868B"/>

                                                    </StackPanel>
                                                </Grid>

                                                <!-- Tin nhắn của mình -->
                                                <Grid x:Name="RightMessage"
                              Visibility="Collapsed">

                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,8,0"
                                        MaxWidth="240">

                                                        <TextBlock Text="{Binding User}"
                                           Margin="0,0,12,4"
                                           FontSize="10"
                                           Foreground="#80868B"
                                           MaxWidth="180"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Right"
                                                                   FontWeight="Medium"/>

                                                        <Border Background="#D2E3FC"
                                        CornerRadius="14"
                                        Padding="12,8"
                                        HorizontalAlignment="Right">

                                                            <TextBlock Text="{Binding Message}"
                                               FontSize="13"
                                               Foreground="#202124"
                                               TextWrapping="Wrap"/>
                                                        </Border>

                                                        <TextBlock Text="{Binding Time}"
                                           HorizontalAlignment="Right"
                                           Margin="0,4,12,0"
                                           FontSize="10"
                                           Foreground="#80868B"/>

                                                    </StackPanel>

                                                    <Border Grid.Column="1"
                                    Width="32"
                                    Height="32"
                                    Background="#1A73E8"
                                    CornerRadius="16"
                                    VerticalAlignment="Top">

                                                        <TextBlock Text="{Binding UserInitials}"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                                    </Border>

                                                </Grid>

                                            </Grid>

                                        </StackPanel>

                                        <DataTemplate.Triggers>

                                            <DataTrigger Binding="{Binding IsMine}" Value="True">
                                                <Setter TargetName="LeftMessage"
                                Property="Visibility"
                                Value="Collapsed"/>
                                                <Setter TargetName="RightMessage"
                                Property="Visibility"
                                Value="Visible"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding ShowSeparator}" Value="True">
                                                <Setter TargetName="Separator"
                                Property="Visibility"
                                Value="Visible"/>
                                            </DataTrigger>

                                        </DataTemplate.Triggers>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </ScrollViewer>

                        <Border Grid.Row="2" BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,16,0,0">
                            <Grid>
                                <TextBox x:Name="txtChatInput" Text="{Binding CurrentChatMessage,
         UpdateSourceTrigger=PropertyChanged}"
             Background="Transparent" BorderThickness="0" Foreground="#202124" FontSize="13" 
             VerticalContentAlignment="Center" Margin="0,0,40,0" KeyDown="txtChatInput_KeyDown"/>

                                <TextBlock Text="Type a message..." Foreground="#9AA0A6" FontSize="13" 
               VerticalAlignment="Center" Margin="5,0,40,0" 
               IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtChatInput}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Button HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" 
            Cursor="Hand" Panel.ZIndex="2" Style="{StaticResource VectorToolStyle}" Command="{Binding SendChatMessageCommand}">
                                    <Path Data="M 22,2 L 11,13 M 22,2 L 15,22 L 11,13 L 2,9 Z"
      Stroke="#B0B3B8" 
      StrokeThickness="1.5"
      StrokeLineJoin="Round"
      StrokeStartLineCap="Round"
      StrokeEndLineCap="Round"
      Fill="Transparent"
      Stretch="Uniform"
      Width="18" Height="18"
      Margin="-2,0,0,0"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ================= OCR TOAST NOTIFICATION ================= -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" 
        Margin="0,0,0,40" Padding="24,12" MinWidth="220"  
        Background="#202124" CornerRadius="22" Panel.ZIndex="999"
         Grid.Row="1" Width="400" Height="53"
        RenderTransformOrigin="0.5,0.5" IsHitTestVisible="False">

            <Border.RenderTransform>
                <ScaleTransform ScaleX="0" ScaleY="0" />
            </Border.RenderTransform>

            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#3C4043"/>
            </Border.Effect>

            <TextBlock Text="✨ Kéo thả chuột để khoanh vùng chữ viết tay..." 
               Foreground="#FFFFFF" FontSize="14" 
               HorizontalAlignment="Left" VerticalAlignment="Center" Margin="17,0,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Opacity" Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOcrToastVisible}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}" />
                                            </ObjectAnimationUsingKeyFrames>

                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3" BeginTime="0:0:0.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Setter Property="Opacity" Value="0" />

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOcrToastVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 From="0.6" To="1" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.8" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 From="0.6" To="1" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.8" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>

                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 To="0.5" Duration="0:0:0.2" />
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>


        <Popup x:Name="ProfilePopover"
       IsOpen="{Binding IsProfilePopoverVisible}"
       Placement="Bottom"
       PlacementTarget="{Binding ElementName=ProfileButton}"
       VerticalOffset="12"
       AllowsTransparency="True"
       PopupAnimation="Fade"
       StaysOpen="False">

            <Border PreviewMouseDown="ProfilePopover_PreviewMouseDown"
            Background="#FFFFFF"
            CornerRadius="8"
            MinWidth="160"
            Padding="0"
            Width="200"
            Height="100">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="8"
                              ShadowDepth="2"
                              Opacity="0.15"
                              Color="#3C4043"/>
                </Border.Effect>

                <StackPanel>

                    <Button Command="{Binding AccountManagerCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    HorizontalContentAlignment="Stretch"
                    Height="50">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="bgBorder1"
                                Background="{TemplateBinding Background}"
                                Padding="16,12"
                                CornerRadius="8,8,0,0">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Path Grid.Column="0"
                                      Data="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10z M4 22a8 8 0 0 1 16 0"
                                      Stroke="#5F6368"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Width="18"
                                      Height="18"
                                      Stretch="Uniform"
                                      Margin="9,4,9,4"/>

                                        <TextBlock Grid.Column="1"
                                           Text="Account manager"
                                           FontSize="14"
                                           Foreground="#202124"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver"
                                     Value="True">

                                        <Setter TargetName="bgBorder1"
                                        Property="Background"
                                        Value="#F8F9FA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding LogoutCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    HorizontalContentAlignment="Stretch"
                    Height="50">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="bgBorder"
                                Background="{TemplateBinding Background}"
                                Padding="16,12"
                                CornerRadius="0,0,8,8"
                                SnapsToDevicePixels="True">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Path Grid.Column="0"
                                      Data="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4 M16 17l5-5-5-5 M21 12H9"
                                      Stroke="#5F6368"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Width="18"
                                      Height="18"
                                      Stretch="Uniform"
                                      Margin="9,4,9,4"/>

                                        <TextBlock Grid.Column="1"
                                           Text="Log out"
                                           FontSize="14"
                                           Foreground="#202124"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver"
                                     Value="True">

                                        <Setter TargetName="bgBorder"
                                        Property="Background"
                                        Value="#F8F9FA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>

            </Border>

        </Popup>
    </Grid>



</UserControl>

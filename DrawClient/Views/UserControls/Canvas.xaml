<UserControl x:Class="DrawClient.Views.UserControls.Canvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DrawClient.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#FFFFFF">
    <UserControl.Resources>
        <Style x:Key="VectorToolStyle" TargetType="Button" >
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borderBg" 
                            CornerRadius="20" 
                            Background="{TemplateBinding Background}">

                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="4"
                                  Width="18" Height="18"/>

                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borderBg" Property="Background" Value="#F1F3F4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="borderBg" Property="Background" Value="#E8F0FE"/>
                                <Setter Property="Foreground" Value="#1A73E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="24,0" Panel.ZIndex="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                    <Button Command="{Binding LeaveRoomCommand}" Background="Transparent" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand" ToolTip="Leave Room" Style="{StaticResource VectorToolStyle}" Width="36">
                        <Path Data="M 18,2 L 6,12 18,22"
      Stroke="Black"
      StrokeThickness="1.5"
      StrokeLineJoin="Round"
      StrokeStartLineCap="Round"
      StrokeEndLineCap="Round"
      Fill="Transparent"
      Stretch="Uniform"
      Width="18" Height="18" RenderTransformOrigin="0.685,0.461" Margin="-2,0,0,0"
                              />
                    </Button>

                    <Rectangle Width="1" Height="24" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding RoomName}" FontSize="16" FontWeight="SemiBold" Foreground="#202124" VerticalAlignment="Center" Margin="0,0,20,0" RenderTransformOrigin="0.664,0.608"/>

                    <Rectangle Width="1" Height="24" Fill="#E8EAED" Margin="0,0,16,0"/>

                    <Button Width="36" Height="36" Background="Transparent" BorderThickness="0" Margin="0,0,8,0" ToolTip="Undo" Cursor="Hand" Style="{StaticResource VectorToolStyle}">
                        <Path Data="M3 7v6h6 M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"
			                  Stroke="#5F6368" StrokeThickness="1.5" Fill="Transparent"
			                  Width="18" Height="18" Stretch="Uniform"
			                  HorizontalAlignment="Center" VerticalAlignment="Center"
			                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>

                    <Button Width="36" Height="36" Background="Transparent" BorderThickness="0" ToolTip="Redo" Cursor="Hand" Style="{StaticResource VectorToolStyle}">
                        <Path Data="M21 7v6h-6 M3 17a9 9 0 0 1 9-9 9 9 0 0 1 6 2.3l3 2.7"
			                  Stroke="#5F6368" StrokeThickness="1.5" Fill="Transparent"
			                  Width="18" Height="18" Stretch="Uniform"
			                  HorizontalAlignment="Center" VerticalAlignment="Center"
			                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>
                </StackPanel>
                <Border Grid.Column="1" Background="#F8F9FA" CornerRadius="8" Margin="40,12" Padding="16,0" MaxWidth="500">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Width="36" Height="36" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Cursor="Hand" Style="{StaticResource VectorToolStyle}">
                            <Path Data="M5 3 L19 12 L5 21 Z"
                  Stroke="#5F6368" StrokeThickness="1.5" Fill="Transparent"
                  Width="16" Height="16" Stretch="Uniform"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  StrokeLineJoin="Round" StrokeStartLineCap="Round" Margin="2.5,0,0,0"/>
                        </Button>

                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center" Margin="16,0">
                            <Slider.Template>
                                <ControlTemplate TargetType="Slider">
                                    <Grid VerticalAlignment="Center">

                                        <Border Height="4" Background="#DADCE0" CornerRadius="2" VerticalAlignment="Center"/>

                                        <Track x:Name="PART_Track">

                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="RepeatButton">
                                                            <Border Height="4" Background="#1A73E8" CornerRadius="2,0,0,2" VerticalAlignment="Center"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.DecreaseRepeatButton>

                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="RepeatButton">
                                                            <Border Background="Transparent"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.IncreaseRepeatButton>

                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Ellipse Width="14" Height="14" Fill="#1A73E8">
                                                                <Ellipse.Effect>
                                                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.25" Color="#3C4043"/>
                                                                </Ellipse.Effect>
                                                            </Ellipse>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>

                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Slider.Template>
                        </Slider>

                        <TextBlock Grid.Column="2" Text="0%" Foreground="#5F6368" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="13"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Width="32" Height="32" Background="#1A73E8" CornerRadius="16">
                    <TextBlock Text="JD" Foreground="White" FontSize="14" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" ClipToBounds="True">

                <InkCanvas x:Name="MyCanvas" Panel.ZIndex="1"
                           MouseDown="Canvas_MouseDown" MouseMove="Canvas_MouseMove" MouseUp="Canvas_MouseUp">
                    <InkCanvas.Background>
                        <DrawingBrush Viewport="0,0,30,30" ViewportUnits="Absolute" TileMode="Tile" Stretch="None">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="#B0B5B9">
                                    <GeometryDrawing.Geometry>
                                        <EllipseGeometry RadiusX="1" RadiusY="1" Center="0,0"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </InkCanvas.Background>
                </InkCanvas>

                <Canvas Panel.ZIndex="2" IsHitTestVisible="False">

                    <Canvas Canvas.Left="350" Canvas.Top="200"/>

                    <Canvas Canvas.Left="480" Canvas.Top="320"/>
                </Canvas>

                <Border HorizontalAlignment="Left" VerticalAlignment="Center" Margin="24,0,0,0" Background="#FFFFFF" CornerRadius="24" Padding="4,12" Panel.ZIndex="5">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#3C4043"/>
                    </Border.Effect>

                    <Border.Resources>
                        <Style x:Key="VectorToolStyle" TargetType="RadioButton">
                            <Setter Property="Foreground" Value="#5F6368"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border CornerRadius="20" Background="{TemplateBinding Background}">
                                            <Path Data="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.5"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="18" Height="18"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Background" Value="#E8F0FE"/>
                                                <Setter Property="Foreground" Value="#1A73E8"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                    <Condition Property="IsChecked" Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter Property="Background" Value="#F1F3F4"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Border.Resources>

                    <StackPanel Width="40">
                        <RadioButton GroupName="Tools" Width="40" Height="40" Margin="0,0,0,8" IsChecked="True" ToolTip="Select" Style="{StaticResource VectorToolStyle}"
                     Content="M4.037 4.688a.495.495 0 0 1 .651-.651l16 6.5a.5.5 0 0 1-.063.947l-6.124 1.58a2 2 0 0 0-1.438 1.435l-1.579 6.126a.5.5 0 0 1-.947.063z"/>

                        <RadioButton GroupName="Tools" Width="40" Height="40" Margin="0,0,0,8" ToolTip="Pen" Style="{StaticResource VectorToolStyle}"
                     Content="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z M15 5l4 4"/>

                        <RadioButton GroupName="Tools" Width="40" Height="40" Margin="0,0,0,8" ToolTip="Eraser" Style="{StaticResource VectorToolStyle}"
                     Content="m7 21-4.3-4.3c-1-1-1-2.5 0-3.4l9.6-9.6c1-1 2.5-1 3.4 0l5.6 5.6c1 1 1 2.5 0 3.4L13 21 M22 21H7 M5 11l9 9"/>

                        <RadioButton GroupName="Tools" Width="40" Height="40" Margin="0,0,0,8" ToolTip="Shapes" Style="{StaticResource VectorToolStyle}"
                     Content="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>

                        <RadioButton GroupName="Tools" Width="40" Height="40" Margin="0,0,0,8" ToolTip="Text" Style="{StaticResource VectorToolStyle}"
                     Content="M4 7V4h16v3 M9 20h6 M12 4v16"/>

                        <RadioButton GroupName="Tools" Width="40" Height="40" ToolTip="OCR Magic" Style="{StaticResource VectorToolStyle}"
                     Content="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z M14 7l3 3 M5 6v4 M19 14v4 M10 2h.01 M20 22h.01 M2 2h.01"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#E8EAED" BorderThickness="1,0,0,0" Panel.ZIndex="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Network Status" FontSize="14" FontWeight="Medium" Foreground="#202124" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding NetworkLogs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Foreground="#5F6368" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Live Chat" FontSize="15" FontWeight="Medium" Foreground="#202124" Margin="0,0,0,16"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ChatMessages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="{Binding User}" FontSize="12" FontWeight="Medium" Foreground="#202124"/>
                                                <TextBlock Text="{Binding Time}" FontSize="12" Foreground="#5F6368" Margin="8,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Message}" FontSize="13" Foreground="#5F6368" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border Grid.Row="2" BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,16,0,0">
                            <Grid>
                                <TextBox x:Name="txtChatInput" 
             Background="Transparent" BorderThickness="0" Foreground="#202124" FontSize="13" 
             VerticalContentAlignment="Center" Margin="0,0,40,0"/>

                                <TextBlock Text="Type a message..." Foreground="#9AA0A6" FontSize="13" 
               VerticalAlignment="Center" Margin="5,0,40,0" 
               IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtChatInput}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Button HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" 
            Cursor="Hand" Panel.ZIndex="2" Style="{StaticResource VectorToolStyle}">
                                    <Path Data="M 22,2 L 11,13 M 22,2 L 15,22 L 11,13 L 2,9 Z"
      Stroke="#B0B3B8" 
      StrokeThickness="1.5"
      StrokeLineJoin="Round"
      StrokeStartLineCap="Round"
      StrokeEndLineCap="Round"
      Fill="Transparent"
      Stretch="Uniform"
      Width="18" Height="18"
      Margin="-2,0,0,0"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>